{
    "name": "vscode-manifest-types",
    "version": "0.3.0",
    "description": "Generate TypeScript typings from a VSCode Extension `package.json`",
    "keywords": [
        "vscode",
        "extension",
        "typescript",
        "manifest",
        "cli",
        "types"
    ],
    "license": "MIT",
    "author": "Richard Robertson",
    "repository": {
        "type": "git",
        "url": "https://github.com/RichardRobertson/vscode-manifest-types.git"
    },
    "type": "module",
    "main": "out/index.js",
    "types": "out/index.d.ts",
    "files": [
